# FLUXO: Adaptive Urban Traffic Intelligence Platform
# Gridlock Hackathon 2.0 · Flipkart × Bengaluru Traffic Police

# Environment
ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://fluxo:fluxo@localhost:5432/fluxo

# Redis
REDIS_URL=redis://localhost:6379

# Models
YOLO_MODEL_PATH=models/yolo11n.pt
RL_MODEL_PATH=models/fluxo_rl_agent_v1.zip
TFT_MODEL_PATH=models/fluxo_tft_v1.pt

# RTSP Streams (set your CCTV stream URLs here)
RTSP_DEFAULT_URL=

# MapmyIndia API
MAP_API_KEY=

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
