# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
*.egg-info/
dist/
build/
.mypy_cache/

# Data (large datasets, keep local only)
data/raw/
data/processed/
data/test/
data/*.csv
data/*.parquet
data/*.json
data/*.mp4
data/*.avi
data/*.mov
data/*.tar.gz
data/*.zip
!data/.gitkeep
!data/README.md

# Model weights (large files, loaded from Hub at runtime)
*.pt
*.pth
*.onnx
*.pb
models/ESPCN*
!models/.gitkeep
# Keep trained helmet model (small, <10MB)
!models/fluxo_helmet_v1.pt

# Qwen2-VL model (loaded from HuggingFace Hub at runtime)
models/qwen2-vl*/

# Outputs
outputs/*
!outputs/.gitkeep

